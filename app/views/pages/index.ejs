<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reajuste Salarial</title>

    <style>
        .erro-input {
            border: 2px solid red;
            background-color: #ffe6e6;
        }

        .mensagem-erro {
            color: red;
            font-size: 14px;
        }

        .resultado {
            color: green;
        }
    </style>
</head>
<body>

    <h1>Reajuste Salarial</h1>

    <form action="/reajuste" method="post">

        <label for="salario">Digite o salário:</label>
        <br>

        <input
            type="number"
            step="0.1"
            name="salario"
            id="salario"
            value="<%= valores.salario %>"
            class="<%= erros.salario ? 'erro-input' : '' %>"
        >

        <br>

        <% if (erros.salario) { %>
            <span class="mensagem-erro">
                Informe um salário maior que zero.
            </span>
            <br>
        <% } %>

        <br>

        <button type="submit">
            Calcular
        </button>

    </form>

    <hr>

    <% if(retorno){ %>

        <% if(retorno.erro){ %>

            <h2 style="color:red;">
                <%= retorno.erro %>
            </h2>

        <% } else { %>

            <h2 class="resultado">Resultado</h2>

            <p>
                Salário antes do reajuste:
                R$ <%= retorno.salario %>
            </p>

            <p>
                Percentual aplicado:
                <%= retorno.percentual %>%
            </p>

            <p>
                Valor do aumento:
                R$ <%= retorno.aumento %>
            </p>

            <p>
                Novo salário:
                R$ <%= retorno.novoSalario %>
            </p>

        <% } %>

    <% } %>

</body>
</html>
