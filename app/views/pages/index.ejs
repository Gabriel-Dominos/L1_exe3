<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Classificação</title>

    <style>
        .erro-input {
            border: 2px solid red;
            background-color: #ffe6e6;
        }

        .mensagem-erro {
            color: red;
            font-size: 14px;
        }

        .resultado {
            color: green;
        }
    </style>
</head>
<body>

    <form action="/classificar" method="post">

        <label>Digite a nota 1:</label><br>

        <input
            type="text"
            name="nota1"
            value="<%= valores.nota1 %>"
            class="<%= erros.nota1 ? 'erro-input' : '' %>"
        >

        <br><br>

        <label>Digite a nota 2:</label><br>

        <input
            type="text"
            name="nota2"
            value="<%= valores.nota2 %>"
            class="<%= erros.nota2 ? 'erro-input' : '' %>"
        >

        <br>

        <% if (erros.nota1 || erros.nota2) { %>
            <span class="mensagem-erro">
                Digite notas válidas entre 0 e 10.
            </span>
            <br>
        <% } %>

        <br>

        <button type="submit">
            Classificar
        </button>

    </form>

    <hr>

    <% if(retorno){ %>

        <% if(retorno.erro){ %>

            <h2 style="color:red;">
                <%= retorno.erro %>
            </h2>

        <% } else { %>

            <h2 class="resultado">
                Nota final: <%= retorno.notafinal %>
            </h2>

            <h2 class="resultado">
                Média: <%= retorno.media %>
            </h2>

        <% } %>

    <% } %>

</body>
</html>
